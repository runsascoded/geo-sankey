{
  "name": "geo-sankey",
  "version": "0.1.0",
  "description": "Pure-geometry library for geographic flow maps: width-proportional ribbon polygons with merge/split layout",
  "homepage": "https://geo-sankey.rbw.sh",
  "repository": "runsascoded/geo-sankey",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./react": "./react/index.ts"
  },
  "files": [
    "dist",
    "react"
  ],
  "scripts": {
    "build": "vite build && mv dist/src/* dist/ && rmdir dist/src",
    "clean": "rm -rf node_modules/.vite dist",
    "dev": "cd site && vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:headful": "HEADFUL=1 vitest run"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19.0.0",
    "puppeteer-core": "^24.40.0",
    "scrns": "^0.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "dependencies": {
    "use-kbd": "https://github.com/runsascoded/use-kbd#e8de7954c2d39b639dc1b99203659b91fd8fd269"
  }
}
